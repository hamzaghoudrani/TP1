        "class ConvNet_Optimized(nn.Module):\n",
        "    def __init__(self):\n",
        "        super(ConvNet_Optimized, self).__init__()\n",
        "        self.features = nn.Sequential(\n",
        "            nn.Conv2d(1, 6, (5, 5), stride=1, padding=2),\n",
